{
  "name": "job-matcher-api",
  "version": "1.0.0",
  "description": "Match candidate profile against job board listings with AI-powered scoring, red flag filtering, and missing skills detection. Pay-per-use · $0.10/call · Built for career agents and HR tech.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:sync-settings": "tsx prisma/sync-settings.ts",
    "db:studio": "prisma studio",
    "check": "tsc --noEmit && eslint src && vitest run && prisma validate"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kolbinski/job-matcher-api.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "bugs": {
    "url": "https://github.com/kolbinski/job-matcher-api/issues"
  },
  "homepage": "https://github.com/kolbinski/job-matcher-api#readme",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.100.1",
    "@prisma/client": "5.22.0",
    "express": "^4.22.2",
    "express-async-errors": "^3.1.1",
    "node-cron": "^4.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/node": "^25.9.1",
    "@types/node-cron": "^3.0.11",
    "@types/supertest": "^7.2.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.4.1",
    "prisma": "5.22.0",
    "supertest": "^7.2.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  }
}
