generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SkillCategory {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String    @unique
  market       String    @default("IT")
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  sort_order   Int       @default(999)
  translations Json?     @default("{}")
  skills       Skill[]

  @@map("skill_categories")
}

model Skill {
  id              String         @id @default(uuid())
  name            String         @unique
  created_at      DateTime       @default(now())
  category_id     String?        @db.Uuid
  was_categorized Boolean        @default(false)
  category        SkillCategory? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("skills")
}

model Settings {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt

  @@map("settings")
}

model User {
  id                                  String        @id @default(uuid())
  email                               String        @unique
  jobmatcher_api_key                  String?       @unique
  created_at                          DateTime      @default(now())
  updated_at                          DateTime      @updatedAt
  profile                             Json?
  password                            String?
  send_job_applied_notifications_hour Int           @default(17)
  utc_offset                          Int           @default(1)
  send_sync_report_notifications_hour Int           @default(9)
  show_agent_info_in_cv               Boolean       @default(true)
  photo_url                           String?
  subscribed_to                       DateTime?
  profile_ready                       Boolean       @default(false)
  profile_synced_at                   DateTime?
  sync_started_at                     DateTime?
  profile_editing_snapshot            Json?
  stripe_customer_id                  String?
  scan_page_counter                   Int       @default(0)
  scan_page_counter_max               Int       @default(0)
  cv_counter                          Int       @default(0)
  cv_counter_max                      Int       @default(0)
  cl_counter                          Int       @default(0)
  cl_counter_max                      Int       @default(0)
  profile_relevant_change_counter     Int       @default(0)
  profile_relevant_change_counter_max Int       @default(0)
  profile_relevant_change_pending     Boolean   @default(false)
  pending_rematch                     Boolean   @default(false)
  review_by_ai_counter                Int       @default(0)
  review_by_ai_counter_max            Int       @default(0)
  status_change_counter               Int       @default(0)
  status_change_counter_max           Int?
  is_admin                            Boolean   @default(false)
  timezone                            String?
  preferred_currency                  String?
  offer_skills                        Json?   @default("[]")
  agent_clients                       AgentClient[]
  api_calls                           ApiCall[]
  push_tokens                         PushToken[]
  user_offers                         UserOffer[]
  user_syncs                          UserSync[]
  feedbacks                           Feedback[]
  subscription                        Subscription?

  @@map("users")
}

model Plan {
  id                String         @id @default(cuid())
  name              String         @unique
  stripe_price_id   String?
  limits            Json
  features          Json
  is_active         Boolean        @default(true)
  created_at        DateTime       @default(now())
  max_status_change Int?
  subscriptions     Subscription[]

  @@map("plans")
}

model Subscription {
  id                     String    @id @default(cuid())
  user_id                String    @unique
  plan_id                String
  stripe_subscription_id String?
  status                 String    @default("active")
  current_period_start   DateTime?
  current_period_end     DateTime?
  created_at             DateTime  @default(now())
  updated_at             DateTime  @updatedAt
  user                   User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  plan                   Plan      @relation(fields: [plan_id], references: [id])

  @@map("subscriptions")
}

model Offer {
  slug                    String      @unique
  source                  String
  title                   String
  company_name            String
  company_logo_url        String?
  experience_level        String?
  workplace_type          String?
  working_time            String?
  remote_interview        Boolean?
  required_skills         String[]
  nice_to_have_skills     String[]
  employment_types        Json
  multilocation           Json?
  city                    String?
  street                  String?
  latitude                Decimal?    @db.Decimal(11, 7)
  longitude               Decimal?    @db.Decimal(11, 7)
  category_id             Int?
  open_to_hire_ukrainians Boolean?
  languages               String[]
  url                     String?
  published_at            DateTime?
  fetched_at              DateTime?
  expired_at              DateTime?
  created_at              DateTime    @default(now())
  updated_at              DateTime    @updatedAt
  id                      String      @id @default(uuid())
  is_active               Boolean     @default(true)
  user_offers             UserOffer[]

  @@map("offers")
}

model UserOffer {
  id                       String            @id @default(uuid())
  user_id                  String
  offer_id                 String
  status                   String
  rejection_reason         String?
  claude_score             Int?
  claude_role_fit          String?
  claude_matched_reasons   Json
  missing_skills           String[]
  claude_recommended       Boolean?
  matched_at               DateTime          @default(now())
  updated_at               DateTime          @updatedAt
  agent_withdraw_reason    String?
  cv_language              String?
  cv_status                String?
  cv_url                   String?
  cl_status                String?
  cl_url                   String?
  salary_currency          String?
  salary_contract_delta    Float?
  salary_permanent_delta   Float?
  is_starred               Boolean           @default(false)
  status_history           UserOfferStatus[]
  offer                    Offer             @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  user                     User              @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, offer_id])
  @@map("user_offers")
}

model UserOfferStatus {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_offer_id   String
  status          String
  created_at      DateTime  @default(now())
  client_notified Boolean   @default(false)
  user_offer      UserOffer @relation(fields: [user_offer_id], references: [id], onDelete: Cascade)

  @@map("user_offer_statuses")
}

model Agent {
  id                  String        @id @default(uuid())
  email               String        @unique
  password_hash       String
  created_at          DateTime      @default(now())
  first_name          String        @default("")
  last_name           String        @default("")
  first_name_genitive String?
  last_name_genitive  String?
  phone               String?
  photo_url           String?
  clients             AgentClient[]
  feedbacks           Feedback[]

  @@map("agents")
}

model AgentClient {
  id       String @id @default(uuid())
  agent_id String
  user_id  String
  agent    Agent  @relation(fields: [agent_id], references: [id])
  user     User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([agent_id, user_id])
  @@map("agent_clients")
}

model ApiCall {
  id             String   @id @default(uuid())
  user_id        String
  called_at      DateTime @default(now())
  offers_matched Int?
  offers_total   Int?
  response_ms    Int?
  status         String
  error_message  String?
  input_tokens   Int      @default(0)
  output_tokens  Int      @default(0)
  call_type      String?
  model          String?
  user           User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("api_calls")
}

model OfferFetch {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source            String
  new_inserts_count Int
  fetched_at        DateTime

  @@map("offer_fetches")
}

model UserSync {
  id         String   @id @default(uuid())
  user_id    String
  report     Json
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_syncs")
}

model Prospect {
  id         String   @id @default(uuid())
  email      String   @unique
  role       String
  status     String   @default("pending")
  notes      String?
  created_at DateTime @default(now())

  @@map("prospects")
}

model PushToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  platform   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("push_tokens")
}

model Feedback {
  id         String   @id @default(cuid())
  message    String
  user_id    String?
  agent_id   String?
  source     String
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])
  agent      Agent?   @relation(fields: [agent_id], references: [id])

  @@map("feedbacks")
}

model AiUsage {
  id            String   @id @default(uuid())
  user_id       String?
  email         String?
  type          String
  model         String
  input_tokens  Int
  output_tokens Int
  cost          Float
  created_at    DateTime @default(now())

  @@map("ai_usage")
}

model NotificationLock {
  id         String   @id @default(cuid())
  lock_key   String   @unique
  created_at DateTime @default(now())

  @@map("notification_locks")
}

model UserDeleted {
  id             String   @id @default(uuid())
  user_id        String
  email          String
  delete_reasons String[] @default([])
  feedback       String?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@map("user_deleted")
}
