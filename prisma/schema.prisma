generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SkillCategory {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String    @unique
  market     String    @default("IT")
  created_at DateTime? @default(now()) @db.Timestamptz(6)
  sort_order Int       @default(999)
  skills     Skill[]

  @@map("skill_categories")
}

model Skill {
  id          String         @id @default(uuid())
  name        String         @unique
  created_at  DateTime       @default(now())
  category_id String?        @db.Uuid
  category    SkillCategory? @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@map("skills")
}

model Settings {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt

  @@map("settings")
}

model User {
  id                                  String        @id @default(uuid())
  email                               String        @unique
  jobmatcher_api_key                  String        @unique
  created_at                          DateTime      @default(now())
  updated_at                          DateTime      @updatedAt
  profile                             Json?
  password                            String?
  send_job_applied_notifications_hour Int           @default(17)
  utc_offset                          Int           @default(1)
  send_sync_report_notifications_hour Int           @default(9)
  show_agent_info_in_cv               Boolean       @default(true)
  photo_url                           String?
  subscribed_to                       DateTime?
  profile_ready                       Boolean       @default(false)
  agent_clients                       AgentClient[]
  api_calls                           ApiCall[]
  push_tokens                         PushToken[]
  user_offers                         UserOffer[]
  user_syncs                          UserSync[]
  feedbacks                           Feedback[]

  @@map("users")
}

model Offer {
  slug                    String      @unique
  source                  String
  title                   String
  company_name            String
  company_logo_url        String?
  experience_level        String?
  workplace_type          String?
  working_time            String?
  remote_interview        Boolean?
  required_skills         String[]
  nice_to_have_skills     String[]
  employment_types        Json
  multilocation           Json?
  city                    String?
  street                  String?
  latitude                Decimal?    @db.Decimal(11, 7)
  longitude               Decimal?    @db.Decimal(11, 7)
  category_id             Int?
  open_to_hire_ukrainians Boolean?
  languages               String[]
  url                     String?
  published_at            DateTime?
  fetched_at              DateTime?
  created_at              DateTime    @default(now())
  updated_at              DateTime    @updatedAt
  id                      String      @id @default(uuid())
  is_active               Boolean     @default(true)
  user_offers             UserOffer[]

  @@map("offers")
}

model UserOffer {
  id                       String            @id @default(uuid())
  user_id                  String
  offer_id                 String
  status                   String
  rejection_reason         String?
  claude_score             Int?
  claude_role_fit          String?
  claude_matched_reasons   String[]
  claude_missing_skills    String[]
  claude_salary_comparison String?
  claude_recommended       Boolean?
  matched_at               DateTime          @default(now())
  updated_at               DateTime          @updatedAt
  agent_withdraw_reason    String?
  cv_language              String?
  cv_status                String?
  cv_url                   String?
  cl_status                String?
  cl_url                   String?
  status_history           UserOfferStatus[]
  offer                    Offer             @relation(fields: [offer_id], references: [id], onDelete: Cascade)
  user                     User              @relation(fields: [user_id], references: [id])

  @@unique([user_id, offer_id])
  @@map("user_offers")
}

model UserOfferStatus {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_offer_id   String
  status          String
  created_at      DateTime  @default(now())
  client_notified Boolean   @default(false)
  user_offer      UserOffer @relation(fields: [user_offer_id], references: [id], onDelete: Cascade)

  @@map("user_offer_statuses")
}

model Agent {
  id                  String        @id @default(uuid())
  email               String        @unique
  password_hash       String
  created_at          DateTime      @default(now())
  first_name          String        @default("")
  last_name           String        @default("")
  first_name_genitive String?
  last_name_genitive  String?
  phone               String?
  photo_url           String?
  clients             AgentClient[]
  feedbacks           Feedback[]

  @@map("agents")
}

model AgentClient {
  id       String @id @default(uuid())
  agent_id String
  user_id  String
  agent    Agent  @relation(fields: [agent_id], references: [id])
  user     User   @relation(fields: [user_id], references: [id])

  @@unique([agent_id, user_id])
  @@map("agent_clients")
}

model ApiCall {
  id             String   @id @default(uuid())
  user_id        String
  called_at      DateTime @default(now())
  offers_matched Int?
  offers_total   Int?
  response_ms    Int?
  status         String
  error_message  String?
  user           User     @relation(fields: [user_id], references: [id])

  @@map("api_calls")
}

model OfferFetch {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  source            String
  new_upserts_count Int
  fetched_at        DateTime

  @@map("offer_fetches")
}

model UserSync {
  id         String   @id @default(uuid())
  user_id    String
  report     Json
  created_at DateTime @default(now())
  user       User     @relation(fields: [user_id], references: [id])

  @@map("user_syncs")
}

model Prospect {
  id         String   @id @default(uuid())
  email      String   @unique
  role       String
  status     String   @default("pending")
  notes      String?
  created_at DateTime @default(now())

  @@map("prospects")
}

model PushToken {
  id         String   @id @default(uuid())
  user_id    String
  token      String   @unique
  platform   String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  user       User     @relation(fields: [user_id], references: [id])

  @@map("push_tokens")
}

model Feedback {
  id         String   @id @default(cuid())
  message    String
  user_id    String?
  agent_id   String?
  source     String
  created_at DateTime @default(now())
  user       User?    @relation(fields: [user_id], references: [id])
  agent      Agent?   @relation(fields: [agent_id], references: [id])

  @@map("feedbacks")
}

model NotificationLock {
  id         String   @id @default(cuid())
  lock_key   String   @unique
  created_at DateTime @default(now())

  @@map("notification_locks")
}
