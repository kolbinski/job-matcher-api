generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl bypasses PgBouncer for Prisma CLI (migrate, introspect)
  directUrl = env("DIRECT_URL")
}

model Settings {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt

  @@map("settings")
}

model User {
  id                 String   @id @default(uuid())
  email              String   @unique
  jobmatcher_api_key String   @unique
  profile_path       String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  api_calls   ApiCall[]
  user_offers UserOffer[]

  @@map("users")
}

// required_skills and nice_to_have_skills are TEXT[] from JustJoin.
// employment_types and multilocation are JSONB to preserve the nested structure.
model Offer {
  id                      String    @id @default(uuid())
  slug                    String    @unique
  source                  String
  title                   String
  company_name            String
  company_logo_url        String?
  experience_level        String?
  workplace_type          String?
  working_time            String?
  remote_interview        Boolean?
  required_skills         String[]
  nice_to_have_skills     String[]
  employment_types        Json      @db.JsonB
  multilocation           Json?     @db.JsonB
  city                    String?
  street                  String?
  latitude                Decimal?  @db.Decimal(11, 7)
  longitude               Decimal?  @db.Decimal(11, 7)
  category_id             Int?
  open_to_hire_ukrainians Boolean?
  languages               String[]
  url                     String?
  published_at            DateTime?
  fetched_at              DateTime?
  is_active               Boolean   @default(true)
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  user_offers UserOffer[]

  @@map("offers")
}

// status values: pre_filter_rejected | ai_rejected | pending_apply | applied |
//   pending_reply_from_recruiter | rejected | offer_received | accepted |
//   client_withdrawn | offer_expired
model UserOffer {
  id                       String   @id @default(uuid())
  user_id                  String
  offer_id                 String
  status                   String
  rejection_reason         String?
  claude_score             Int?
  claude_role_fit          String?
  claude_matched_reasons   String[]
  claude_missing_skills    String[]
  claude_salary_comparison String?
  claude_recommended       Boolean?
  matched_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  user  User  @relation(fields: [user_id], references: [id])
  offer Offer @relation(fields: [offer_id], references: [id], onDelete: Cascade)

  @@unique([user_id, offer_id])
  @@map("user_offers")
}

model ApiCall {
  id             String   @id @default(uuid())
  user_id        String
  called_at      DateTime @default(now())
  offers_matched Int?
  offers_total   Int?
  response_ms    Int?
  status         String
  error_message  String?

  user User @relation(fields: [user_id], references: [id])

  @@map("api_calls")
}
