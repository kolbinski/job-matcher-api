generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  // directUrl is required when using Supabase connection pooler (PgBouncer)
  // Uncomment when deploying to Railway + Supabase:
  // directUrl = env("DIRECT_URL")
}

model Settings {
  id         String   @id @default(uuid())
  key        String   @unique
  value      String
  updated_at DateTime @updatedAt

  @@map("settings")
}

model User {
  id                    String   @id @default(uuid())
  email                 String   @unique
  jobmatcher_api_key    String   @unique
  credits               Decimal  @db.Decimal(10, 4)
  auto_refill           Boolean  @default(false)
  auto_refill_amount    Decimal? @db.Decimal(10, 2)
  auto_refill_threshold Decimal? @db.Decimal(10, 2)
  stripe_customer_id    String?
  stripe_payment_method String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  api_calls ApiCall[]

  @@map("users")
}

// required_skills and nice_to_have_skills are TEXT[] from JustJoin.
// JustJoin returns skill names as plain strings — no experience level.
// employment_types and multilocation are JSONB to preserve Apify's nested structure.
model Offer {
  slug                    String    @id
  source                  String
  title                   String
  company_name            String
  company_logo_url        String?
  experience_level        String?
  workplace_type          String?
  working_time            String?
  remote_interview        Boolean?
  required_skills         String[]
  nice_to_have_skills     String[]
  employment_types        Json      @db.JsonB
  multilocation           Json?     @db.JsonB
  city                    String?
  street                  String?
  latitude                Decimal?  @db.Decimal(11, 7)
  longitude               Decimal?  @db.Decimal(11, 7)
  category_id             Int?
  open_to_hire_ukrainians Boolean?
  languages               String[]
  url                     String?
  is_active               Boolean   @default(true)
  published_at            DateTime?
  fetched_at              DateTime?
  created_at              DateTime  @default(now())
  updated_at              DateTime  @updatedAt

  @@map("offers")
}

// cost is a snapshot of settings.call_cost at call time — not a FK.
// profile_hash is SHA-256 of the raw profile JSON for deduplication analytics.
model ApiCall {
  id             String   @id @default(uuid())
  user_id        String
  called_at      DateTime @default(now())
  cost           Decimal  @db.Decimal(10, 4)
  profile_hash   String?
  offers_matched Int?
  offers_total   Int?
  response_ms    Int?
  status         String
  error_message  String?

  user User @relation(fields: [user_id], references: [id])

  @@map("api_calls")
}
