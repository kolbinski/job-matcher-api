# PostgreSQL — Supabase connection string
# For Railway + Supabase, use the pooled connection (port 6543) for runtime
# and the direct connection (port 5432) for Prisma migrations via DIRECT_URL
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL="postgresql://postgres.[project-ref]:[password]@db.[project-ref].supabase.co:5432/postgres"

# Anthropic — Claude API (claude-sonnet for AI scoring)
ANTHROPIC_API_KEY="sk-ant-api03-..."

# Stripe — use sk_test_ prefix for development
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Server
PORT=3000
NODE_ENV="development"
